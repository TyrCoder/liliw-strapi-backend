{
  "kind": "collectionType",
  "collectionName": "bookings",
  "info": {
    "singularName": "booking",
    "pluralName": "bookings",
    "displayName": "Booking",
    "description": "Tour booking submissions"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "bookingRef": {
      "type": "string"
    },
    "tourId": {
      "type": "string"
    },
    "tourName": {
      "type": "string"
    },
    "guestName": {
      "type": "string",
      "required": true
    },
    "guestEmail": {
      "type": "email",
      "required": true
    },
    "guestPhone": {
      "type": "string"
    },
    "bookingDate": {
      "type": "date"
    },
    "participants": {
      "type": "integer",
      "default": 1
    },
    "specialRequests": {
      "type": "text"
    },
    "totalCost": {
      "type": "decimal"
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "confirmed", "cancelled"],
      "default": "pending"
    }
  }
}
