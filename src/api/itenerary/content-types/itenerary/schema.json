{
  "kind": "collectionType",
  "collectionName": "iteneraries",
  "info": {
    "singularName": "itenerary",
    "pluralName": "iteneraries",
    "displayName": "Itinerary"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "duration": {
      "type": "enumeration",
      "enum": [
        "half-day",
        "one-day",
        "two-day",
        "heritage",
        "foodie",
        "family"
      ]
    },
    "description": {
      "type": "blocks"
    },
    "stops": {
      "type": "blocks"
    },
    "highlights": {
      "type": "json"
    },
    "included": {
      "type": "json"
    },
    "not_included": {
      "type": "json"
    },
    "difficulty": {
      "type": "enumeration",
      "enum": [
        "easy",
        "moderate",
        "difficult"
      ]
    },
    "price": {
      "type": "integer"
    },
    "max_participants": {
      "type": "integer"
    },
    "cover_photo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "meeting_point": {
      "type": "string"
    },
    "photos": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    }
  }
}
