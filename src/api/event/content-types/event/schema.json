{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "blocks"
    },
    "date_start": {
      "type": "datetime"
    },
    "date_end": {
      "type": "datetime"
    },
    "venue": {
      "type": "string"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "festival",
        "cultural",
        "competition",
        "other"
      ]
    },
    "photos": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "program": {
      "type": "blocks"
    },
    "is_featured": {
      "type": "boolean"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    }
  }
}
