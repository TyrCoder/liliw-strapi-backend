{
  "kind": "collectionType",
  "collectionName": "artisans",
  "info": {
    "singularName": "artisan",
    "pluralName": "artisans",
    "displayName": "Artisan"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "craft_type": {
      "type": "string"
    },
    "description": {
      "type": "blocks"
    },
    "place_type": {
      "type": "enumeration",
      "enum": [
        "artisan_shop",
        "workshop"
      ]
    },
    "location": {
      "type": "string"
    },
    "contact_number": {
      "type": "string"
    },
    "social_media": {
      "type": "string"
    },
    "photos": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "featured_works": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "rating": {
      "type": "integer",
      "min": 1,
      "max": 5
    }
  }
}
